# Parizoda — maxfiy sozlamalar. Nusxa oling:  cp .env.example .env
# .env GIT'GA TUSHMAYDI (.gitignore). Qiymatlarni o'zgartiring!

# PostgreSQL paroli
POSTGRES_PASSWORD=pari_secret_2026

# Sessiya imzolash siri — UZUN, TASODIFIY qiymat qo'ying.
# Yaratish:  openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_to_a_long_random_string

# Sessiya muddati (kun)
SESSION_TTL_DAYS=30

# HTTPS ortida ishlatsangiz 1 qiling (cookie faqat HTTPS orqali yuboriladi)
COOKIE_SECURE=0

# Foydalanuvchilar:  username:parol:DisplayName  (vergul bilan)
# Parollarni o'zgartiring! Display — chat/xotira muallifi sifatida ko'rinadi.
PARI_USERS=parizoda:KUCHLI_PAROL_1:Паризода,jaxongir:KUCHLI_PAROL_2:Жаҳонгир
